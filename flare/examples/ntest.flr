package Main =
    type Point2d = {x: num, y: num}

    type Point3d = {x: num, y: num, z: num}

    type T = {x: num, y: num, ...}

    let slope_xy p q : T -> T -> num =
        (q.y - p.x) / (q.x - p.x)
    
    let main: num =
        let p1 = {x = 2, y = 3, z= 6 } in
        let p2 = {x = 4, y = 5, z=7} in
        slope_xy p1 p2
