package Main =
    extern format: ?T -> str

    let factorial x : num -> num =
        if x == 0 then
            0
        else
            factorial(x - 1) + x

    # for some property, CanTalk
    
    let speak x: {?T , ?T -> str} -> str =
        x.1(x.0)

    let number_speak x: num -> str =
        format x

    let main : str =
        {3, number_speak }      
               
