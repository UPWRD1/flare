	let v7 = v6^1 in #4(v7(v3))
}

fn 5(v0: {unit|{f32,unit}},v1: [({f32,unit})-> {f32,unit}]) -> {unit|{f32,unit}} {
	case v0{#6[],#7[v1: [({f32,unit})-> {f32,unit}]]}
