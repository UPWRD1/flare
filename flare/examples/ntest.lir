fn 1(v1: |{f32,unit}|[(unit)-> {f32,unit}],v0: unit) -> {f32,unit} {
	let v2 = v1^1 in v2
}

fn 2(v4: ||[({f32,unit})-> {f32,unit}],v3: {f32,unit}) -> {f32,unit} {
	v3
}

fn 0(v0: {unit|{f32,unit}},v1: {f32,unit}) -> {f32,unit} {
	case v0{#1[v1: {f32,unit}],#2[]}
}
---------------------


fn 3() -> {unit|{f32,unit}} {
