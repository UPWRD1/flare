
fn 0(v0: {f32,unit}) -> f32 {
	v0.0
}
---------------------


fn 1(v0: {f32,unit},v1: [(f32)-> f32]) -> {f32,unit} {
	{v1(v0.0),v0.1}
}
---------------------


fn 2(v0: f32) -> f32 {
	v0
}
---------------------


fn 3(v0: f32) -> {f32,unit} {
	{#2(v0),unit}
}
---------------------

fn 5(v1: ||[(f32)-> f32],v0: f32) -> f32 {
	v0 * 2f
}

fn 4() -> f32 {
	#0(#1(#3(10f),#5[])) - 20f
}
