package Main = 

	extern ex_concat: str -> str -> str
	
	struct Data =
		f1: num,
		f2: str

	
	let add_three x : num -> num = 
		x + 3

	let mult x y : ?T -> ?T =
		x * y

	let cube x : ?T -> ?T = x * x * x

	let concat l r : str -> str -> str =
		ex_concat l r


	let main x : ?T = 
		let a = Data { f1 = cube 3, f2 = "cat" } in
			let b = Data { f1 = add_three 2, f2 = "con" } in
				Data {f1 = mult(a.f1 b.f1), f2 = concat(a.f2 b.f2)}
